      "faults_maintenance": "https://images.unsplash.com/photo-1559678158-4bbf3a63ccf7?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAxODF8MHwxfHNlYXJjaHwzfHxtb2Rlcm4lMjBidWlsZGluZyUyMGlsbHVzdHJhdGlvbiUyMGZsYXQlMjBkZXNpZ24lMjBibHVlJTIwdHJlZXN8ZW58MHx8fHwxNzczNDAyNjcwfDA&ixlib=rb-4.1.0&q=85",
      "documents": "https://images.unsplash.com/photo-1771758249853-415175dc29b9?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMzJ8MHwxfHNlYXJjaHwyfHxzdGFjayUyMG9mJTIwYnVzaW5lc3MlMjBkb2N1bWVudHMlMjBjbGVhbnxlbnwwfHx8fDE3NzM0MDI2NzF8MA&ixlib=rb-4.1.0&q=85",
      "appointments": "https://images.unsplash.com/photo-1636125657985-7384a5478f5a?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1NzZ8MHwxfHNlYXJjaHwyfHxtb2Rlcm4lMjBtZWV0aW5nJTIwcm9vbSUyMGdsYXNzJTIwd2FsbHN8ZW58MHx8fHwxNzczNDAyNjcyfDA&ixlib=rb-4.1.0&q=85",
      "contacts_map": "https://images.unsplash.com/photo-1715527532135-80764537c278?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODF8MHwxfHNlYXJjaHwxfHxTYWxlcm5vJTIwSXRhbHklMjBjaXR5JTIwc3RyZWV0JTIwbWFwfGVufDB8fHx8MTc3MzQwMjY3M3ww&ixlib=rb-4.1.0&q=85",
      "team_about": "https://images.unsplash.com/photo-1758873271761-6cfe9b4f000c?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODh8MHwxfHNlYXJjaHw0fHxjb3Jwb3JhdGUlMjBtZWV0aW5nJTIwZGl2ZXJzZSUyMHRlYW0lMjBwcm9mZXNzaW9uYWx8ZW58MHx8fHwxNzczNDAyNjk4fDA&ixlib=rb-4.1.0&q=85"
    }
  },
  "universal_guidelines": {
    "react_native": [
      "Use `StyleSheet.create` for all styles; avoid inline styles where possible.",
      "Use `SafeAreaView` from `react-native-safe-area-context` for all screen containers.",
      "Wrap forms in `KeyboardAvoidingView` (behavior: padding/height based on platform).",
      "Use `TouchableOpacity` or `Pressable` for all interactive elements.",
      "Ensure `hitSlop={{top: 10, bottom: 10, left: 10, right: 10}}` for small icons.",
      "Use `FlatList` for all lists (performance); never `ScrollView` + `map`.",
      "Platform.OS === 'android' ? 'elevation' : 'shadow...' for shadows."
    ],
    "accessibility": [
      "All text must have `accessible={true}` (default).",
      "Images must have `accessibilityLabel`.",
      "Touchable elements must have `accessibilityRole` (button, link, etc.).",
      "Minimum contrast ratio 4.5:1 for text."
    ],
    "testing": [
      "All interactive elements MUST include `testID` prop (e.g., `testID='login-button'`).",
      "Text elements containing dynamic data should have `testID`."
    ]
  },
  "instructions_to_main_agent": "You are building a React Native Expo app. The file structure suggests Expo Router. Use 'app' directory for routing. Do not use Tailwind classes as 'nativewind' is not detected in package.json. Use standard React Native StyleSheet. Stick to the requested color palette (#1B3A5C, #5B9BD5). The design should be clean, large, and readable. Use the provided image URLs for placeholders."
}