{
  "project_name": "Studio Tardugno & Bonifacio Mobile App",
  "platform": "React Native Expo (Android-first)",
  "design_philosophy": {
    "identity": "The Trustworthy Neighbor",
    "core_principles": [
      "Clarity over Style: Text must be legible for elderly users (16px+ body).",
      "Touch-First: Minimum touch target 48x48px.",
      "Professional Warmth: Corporate Navy meets Sky Blue; reliable but not cold.",
      "Native Feel: Use platform-specific navigation patterns (Tabs, Stacks).",
      "Italian Elegance: Clean lines, ample whitespace, high-contrast typography."
    ],
    "anti_patterns": [
      "Small text (<14px) for interactive elements.",
      "Low contrast grays.",
      "Complex gestures (swipe actions must have button alternatives).",
      "Hidden navigation (Hamburger menus are secondary; Tabs are primary)."
    ]
  },
  "typography": {
    "font_family": {
      "heading": "Manrope",
      "body": "Inter"
    },
    "scale": {
      "xs": 12,
      "sm": 14,
      "md": 16,
      "lg": 18,
      "xl": 20,
      "2xl": 24,
      "3xl": 30,
      "4xl": 36
    },
    "weights": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "line_heights": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75
    },
    "usage": {
      "h1": { "size": 30, "weight": "700", "color": "#1B3A5C", "lineHeight": 36 },
      "h2": { "size": 24, "weight": "600", "color": "#1B3A5C", "lineHeight": 30 },
      "h3": { "size": 20, "weight": "600", "color": "#1B3A5C", "lineHeight": 26 },
      "body": { "size": 16, "weight": "400", "color": "#334155", "lineHeight": 24 },
      "caption": { "size": 12, "weight": "500", "color": "#64748B", "lineHeight": 16 },
      "button": { "size": 16, "weight": "600", "color": "#FFFFFF", "lineHeight": 20 }
    }
  },
  "colors": {
    "primary": {
      "navy": "#1B3A5C",
      "sky": "#5B9BD5",
      "sky_light": "#E0F2FE"
    },
    "neutral": {
      "white": "#FFFFFF",
      "background": "#F8FAFC",
      "surface": "#FFFFFF",
      "border": "#E2E8F0",
      "text_main": "#0F172A",
      "text_secondary": "#475569",
      "text_muted": "#94A3B8"
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6"
    },
    "dashboard_tiles": [
      { "bg": "#E0F2FE", "icon": "#0284C7" }, 
      { "bg": "#DCFCE7", "icon": "#16A34A" }, 
      { "bg": "#FEF3C7", "icon": "#D97706" }, 
      { "bg": "#FEE2E2", "icon": "#DC2626" },
      { "bg": "#F3E8FF", "icon": "#9333EA" },
      { "bg": "#FFEDD5", "icon": "#EA580C" }
    ]
  },
  "spacing": {
    "grid_unit": 4,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48,
    "3xl": 64,
    "safe_area_bottom": 34
  },
  "layout": {
    "grid_system": {
      "dashboard_cols": 2,
      "gap": 16,
      "container_padding": 16
    },
    "card": {
      "borderRadius": 12,
      "padding": 16,
      "backgroundColor": "#FFFFFF",
      "shadowColor": "#000",
      "shadowOffset": { "width": 0, "height": 2 },
      "shadowOpacity": 0.05,
      "shadowRadius": 8,
      "elevation": 3
    },
    "container": {
      "flex": 1,
      "backgroundColor": "#F8FAFC"
    }
  },
  "components": {
    "buttons": {
      "primary": {
        "height": 56,
        "borderRadius": 12,
        "backgroundColor": "#1B3A5C",
        "justifyContent": "center",
        "alignItems": "center"
      },
      "secondary": {
        "height": 56,
        "borderRadius": 12,
        "backgroundColor": "#E0F2FE",
        "justifyContent": "center",
        "alignItems": "center",
        "borderWidth": 1,
        "borderColor": "#5B9BD5"
      },
      "text_style": {
        "color": "#FFFFFF",
        "fontSize": 16,
        "fontWeight": "600"
      }
    },
    "inputs": {
      "height": 56,
      "borderRadius": 8,
      "borderWidth": 1,
      "borderColor": "#E2E8F0",
      "backgroundColor": "#FFFFFF",
      "paddingHorizontal": 16,
      "fontSize": 16,
      "color": "#0F172A"
    }
  },
  "assets": {
    "icons_library": "@expo/vector-icons (Ionicons or MaterialIcons)",
    "images": {
